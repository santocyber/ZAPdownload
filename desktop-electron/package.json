{
  "name": "zapviewer-desktop",
  "version": "1.0.0",
  "description": "ZapViewer desktop app for local WhatsApp exports",
  "main": "dist/main/main.js",
  "type": "commonjs",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build": "npm run build:main && npm run build:preload && vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "tsc -p tsconfig.preload.json",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.main.json && tsc --noEmit -p tsconfig.preload.json",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "better-sqlite3": "^11.8.1",
    "dayjs": "^1.11.13",
    "mime-types": "^2.1.35",
    "sanitize-filename": "^1.6.3",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/better-sqlite3": "^7.6.12",
    "@types/mime-types": "^2.1.4",
    "@types/node": "^22.10.7",
    "@types/sanitize-filename": "^1.6.3",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^34.0.2",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "wait-on": "^8.0.2"
  },
  "build": {
    "appId": "com.zapviewer.desktop",
    "productName": "ZapViewer",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "win": {
      "target": [
        "portable"
      ],
      "artifactName": "ZapViewer-Windows.exe"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "artifactName": "ZapViewer-macOS.dmg"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "artifactName": "ZapViewer-Linux.AppImage",
      "category": "Utility"
    }
  }
}
